# Environment Variables - Backend
# Salin file ini ke .env dan isi semua nilai yang diperlukan

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database MySQL ───────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=uas_webdin

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Ganti dengan string acak yang panjang dan kuat untuk production!
JWT_SECRET=ganti_dengan_secret_yang_kuat_dan_panjang
JWT_EXPIRES_IN=1d

# ─── SMTP (Nodemailer) ────────────────────────────────────────────────────────
# Untuk TESTING (development), gunakan Mailtrap: https://mailtrap.io
# Untuk PRODUCTION, gunakan Gmail App Password atau layanan SMTP lain

# Contoh konfigurasi Mailtrap (development):
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=<username-dari-mailtrap>
# SMTP_PASS=<password-dari-mailtrap>

# Contoh konfigurasi Gmail (production):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=emailanda@gmail.com
# SMTP_PASS=<app-password-bukan-password-biasa>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
